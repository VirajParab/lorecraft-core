# LoreCraft Core — copy to .env and fill in values
# cp .env.example .env

# Hugging Face (required for Flux + Qwen model downloads)
HF_TOKEN=

# Paths (defaults work if you use make install-all)
LORECRAFT_ROOT=
VENDOR_DIR=vendor
MODELS_DIR=models
DATA_DIR=data
VENV_DIR=.venv

# Service ports
VLLM_PORT=8000
COMFYUI_PORT=8188
COSYVOICE_PORT=9001
CORE_API_PORT=8080

# LLM (vLLM)
VLLM_MODEL=Qwen/Qwen3-8B
# Production: Qwen/Qwen3-32B-AWQ
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTILIZATION=0.90

# ComfyUI
COMFYUI_HOST=127.0.0.1
COMFYUI_EXTRA_ARGS=

# Image / style
FLUX_MODEL=black-forest-labs/FLUX.1-dev
PONY_LORA_URL=
# Civitai Pony V6 XL — set URL or place file at models/loras/pony_v6.safetensors manually

# TTS
COSYVOICE_MODEL_DIR=models/cosyvoice

# FX video (optional — heavy download)
WAN_MODEL_DIR=models/wan
ENABLE_WAN=false

# Compositor
COMPOSITOR_FPS=30
COMPOSITOR_WIDTH=1920
COMPOSITOR_HEIGHT=1080

# CUDA
CUDA_VISIBLE_DEVICES=0
